{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "clawd",
  "version": "0.1.0",
  "identifier": "com.clawd.pet",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Clawd",
        "width": 200,
        "height": 200,
        "x": 1000,
        "y": 600,
        "transparent": true,
        "alwaysOnTop": true,
        "decorations": false,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false,
        "dragDropEnabled": true,
        "fullscreen": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
